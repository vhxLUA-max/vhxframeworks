local function req(method, ep, body, prefer)
    local h = {}
    for k,v in pairs(BASE) do h[k]=v end
    if body then h["Content-Type"] = "application/json" end
    if prefer then h["Prefer"] = prefer end
    local ok, r = pcall(httpRequest, {
        Url=SUPABASE_URL..ep, Method=method, Headers=h,
        Body=body and (type(body)=="string" and body or HttpService:JSONEncode(body)) or nil
    })
    return ok and r or nil
end

local function decode(r)
    if not r or not r.Body then return nil end
    local ok, d = pcall(HttpService.JSONDecode, HttpService, r.Body)
    return ok and d or nil
end

local function httpGet(url)
    local ok, r = pcall(httpRequest, { Url=url, Method="GET" })
    if not ok or not r then return nil end
    local ok2, d = pcall(HttpService.JSONDecode, HttpService, r.Body or "")
    return ok2 and d or nil
end

