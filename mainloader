-- ── Fingerprint ───────────────────────────────────────────────────────────────
local function genFingerprint()
    local executor = (identifyexecutor and identifyexecutor()) or
                     (getexecutorname and getexecutorname()) or "unknown"
    local seed = tostring(LP.UserId)..executor..tostring(game.GameId)
    local hash = 0
    for i = 1, #seed do hash = (hash * 31 + string.byte(seed, i)) % 2147483647 end
    return string.format("FP-%x-%d", hash, LP.UserId % 99999)
end

-- ── HWID ──────────────────────────────────────────────────────────────────────
local function genHWID()
    local executor = (identifyexecutor and identifyexecutor()) or
                     (getexecutorname and getexecutorname()) or "unk"
    local seed = tostring(LP.UserId)..executor..tostring(game.GameId)
    local hash = 5381
    for i = 1, #seed do hash = ((hash * 33) + string.byte(seed, i)) % 4294967295 end
    return string.format("HW-%x", hash)
end

