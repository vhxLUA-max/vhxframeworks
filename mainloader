local function genToken()
    return WORDS[math.random(1,#WORDS)] .. tostring(math.random(1000,9999))
end

local placeId = game.PlaceId
local now     = os.date("!%Y-%m-%dT%H:%M:%SZ")

task.spawn(function()
    POST("/rest/v1/rpc/increment_execution", '{"p_place_id":'..tostring(placeId)..'}')

    local res = GET(("/rest/v1/unique_users?roblox_user_id=eq.%d&place_id=eq.%d&select=token,first_seen"):format(LP.UserId, placeId))
    local token, firstSeen = nil, now

    if res and res.Body then
        local ok, data = pcall(HttpService.JSONDecode, HttpService, res.Body)
        if ok and data and #data > 0 then
            token     = data[1].token
            firstSeen = data[1].first_seen or now
        end
    end

    if not token then
        token = genToken()
    end

    POST("/rest/v1/rpc/upsert_user", {
        p_roblox_user_id = LP.UserId,
        p_username       = LP.Name,
        p_place_id       = placeId,
        p_first_seen     = firstSeen,
        p_last_seen      = now,
        p_token          = token,
    })

    if getgenv then getgenv()._vhxToken = token end
end)

