        HttpService:UrlEncode(gameName))))
    if mRes and #mRes > 0 and mRes[1].maintenance then
        local msg   = mRes[1].maintenance_msg or "This script is under maintenance. Check back soon."
        local endTs = mRes[1].end_timestamp

        local remainingAtFetch = -1
        if endTs then
            pcall(function()
                local nowRes   = decode(req("GET", "/rest/v1/rpc/now"))
                local serverNow = nowRes or os.date("!%Y-%m-%dT%H:%M:%SZ")
                local function isLeap(yr) return (yr%4==0 and yr%100~=0) or yr%400==0 end
                local function daysSinceEpoch(yr,mo,dy)
                    local days = 0
                    for y2=1970,yr-1 do days=days+(isLeap(y2) and 366 or 365) end
                    local md={31,28,31,30,31,30,31,31,30,31,30,31}
                    if isLeap(yr) then md[2]=29 end
                    for m2=1,mo-1 do days=days+md[m2] end
                    return days+dy-1
                end
                local function parseISO(s)
                    local y,mo,d,hh,mm,ss = s:match("(%d+)-(%d+)-(%d+)T(%d+):(%d+):(%d+)")
                    if not y then return nil end
                    return daysSinceEpoch(tonumber(y),tonumber(mo),tonumber(d))*86400
                           + tonumber(hh)*3600 + tonumber(mm)*60 + tonumber(ss)
                end
                local endSecs = parseISO(endTs)
                local nowSecs = parseISO(tostring(serverNow):sub(1,19))
                if endSecs and nowSecs then
                    remainingAtFetch = math.max(0, endSecs - nowSecs)
                end
