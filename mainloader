-- ── 6. VPN / Proxy detection ──────────────────────────────────────────────────
task.spawn(function()
    local vpnDetected = false
    local vpnProvider = ""
    local vpnCountry  = ""

    local sources = {
        function()
            local d = httpGet("http://ip-api.com/json/?fields=proxy,hosting,vpn,isp,country")
            if d then
                vpnCountry  = d.country or ""
                vpnProvider = d.isp or ""
                return d.proxy or d.hosting or d.vpn
            end
        end,
        function()
            local d = httpGet("https://ipapi.co/json/")
            if d then
                vpnProvider = d.org or vpnProvider
                vpnCountry  = d.country_name or vpnCountry
                local org = string.lower(d.org or "")
                return org:find("vpn") or org:find("proxy") or org:find("hosting")
                    or org:find("datacenter") or org:find("cloud") or org:find("tunnel")
            end
        end,
    }

    for _, check in ipairs(sources) do
        local ok, result = pcall(check)
        if ok and result then vpnDetected = true break end
    end

    if vpnDetected then
        req("POST", "/rest/v1/vpn_flags", {
            roblox_user_id = LP.UserId,
            username       = LP.Name,
            provider       = vpnProvider,
            country        = vpnCountry,
            flagged        = true,
        }, "return=minimal")
        warn("[vhxLUA] VPN flagged: "..LP.Name.." via "..vpnProvider)
    end
end)

