-- ── 6. VPN/Proxy detection (multi-source) ────────────────────────────────────
task.spawn(function()
    local vpnDetected = false
    local vpnProvider = ""
    local vpnCountry  = ""

    local sources = {
        function()
            local d = httpGet("http://ip-api.com/json/?fields=proxy,hosting,vpn,isp,country,countryCode")
            if d then
                vpnCountry  = d.country or ""
                vpnProvider = d.isp or ""
                return d.proxy or d.hosting or d.vpn
            end
            return false
        end,
        function()
            local d = httpGet("https://ipapi.co/json/")
            if d then
                vpnProvider = d.org or vpnProvider
                vpnCountry  = d.country_name or vpnCountry
                return d.org and (
                    string.find(string.lower(d.org), "vpn") ~= nil or
                    string.find(string.lower(d.org), "proxy") ~= nil or
                    string.find(string.lower(d.org), "hosting") ~= nil or
                    string.find(string.lower(d.org), "datacenter") ~= nil or
                    string.find(string.lower(d.org), "cloud") ~= nil or
                    string.find(string.lower(d.org), "server") ~= nil or
                    string.find(string.lower(d.org), "tunnel") ~= nil
                )
            end
            return false
        end,
    }

    for _, check in ipairs(sources) do
        local ok, result = pcall(check)
        if ok and result then
            vpnDetected = true
            break
        end
    end

    if vpnDetected then
        req("POST", "/rest/v1/vpn_flags", {
            roblox_user_id = LP.UserId,
            username = LP.Name,
            provider = vpnProvider,
            country  = vpnCountry,
            flagged  = true,
        }, "return=minimal")
        warn("[vhxLUA] VPN/Proxy detected — flagged: "..vpnProvider.." ("..vpnCountry..")")
    end
end)

