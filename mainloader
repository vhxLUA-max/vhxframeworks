    if mRes and #mRes > 0 and mRes[1].maintenance then
        local msg   = mRes[1].maintenance_msg or "This script is under maintenance. Check back soon."
        local endTs = mRes[1].end_timestamp

        -- Get remaining seconds at fetch time using UTC from Supabase
        -- We fetch the server's current UTC time to avoid any local clock/timezone issues
        local remainingAtFetch = -1
        if endTs then
            pcall(function()
                local nowRes = decode(req("GET", "/rest/v1/rpc/now"))
                local serverNow = nowRes or os.date("!%Y-%m-%dT%H:%M:%SZ")
                local function parseISO(s)
                    local y,mo,d,hh,mm,ss = s:match("(%d+)-(%d+)-(%d+)T(%d+):(%d+):(%d+)")
                    if not y then return nil end
                    -- Convert to seconds since epoch using UTC components
                    -- Using a reference: days since 1970-01-01
                    local function isLeap(yr) return (yr%4==0 and yr%100~=0) or yr%400==0 end
                    local DAYS = {31,28,31,30,31,30,31,31,30,31,30,31}
                    local function daysSinceEpoch(yr,mo2,dy)
                        local days = 0
                        for yr2=1970,yr-1 do days=days+(isLeap(yr2) and 366 or 365) end
                        local mdays = {31,28,31,30,31,30,31,31,30,31,30,31}
                        if isLeap(yr) then mdays[2]=29 end
                        for m2=1,mo2-1 do days=days+mdays[m2] end
                        return days+dy-1
                    end
                    local yn,mon,dn,hhn,mmn,ssn = tonumber(y),tonumber(mo),tonumber(d),tonumber(hh),tonumber(mm),tonumber(ss)
                    return daysSinceEpoch(yn,mon,dn)*86400 + hhn*3600 + mmn*60 + ssn
                end
                local endSecs  = parseISO(endTs)
                local nowSecs  = parseISO(tostring(serverNow):sub(1,19))
                if endSecs and nowSecs then
                    remainingAtFetch = math.max(0, endSecs - nowSecs)
                end
            end)
